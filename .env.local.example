# Zeus Lifts — Supabase configuration
#
# OPTIONAL. Without these, the app runs entirely on localStorage (great for
# trying it out). Add them to sync data via Supabase Postgres across devices.
#
# 1. Create a project at https://supabase.com
# 2. Run supabase/migrations/0001_init.sql in the SQL editor
# 3. Copy this file to .env.local and paste your Project URL + anon public key
#    (Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
